# The captured CLI/MCP help is embedded verbatim into the reference tables, so
# its line endings must be deterministic across platforms regardless of a
# contributor's core.autocrlf setting — otherwise a Windows re-capture would
# produce a spurious whole-file diff.
captured-help/*.txt text eol=lf
captured-help/*.json text eol=lf

# The generated reference tables are written by tools/generate_flag_tables.py
# with platform newlines; pin them LF too so a Windows re-capture doesn't flip
# the whole file to CRLF.
skills/*/references/*.md text eol=lf
